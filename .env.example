# PKeet User Dashboard – frontend env
# Copy to .env.local and set values

# API base URL (leave empty to use Vite proxy to http://localhost:5050)
VITE_API_URL=

# Stripe: no frontend secret key. Configure the API with Stripe:SecretKey (sk_test_…).
# UPI: set API Stripe:CheckoutCurrency to INR (see orio-web-api appsettings). USD checkout does not support UPI.

# Google OAuth client ID (Web application type) – required for "Sign in with Google"
# Get it from https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=
